# =============================================
#  Classic Barbershop — Plantilla de entorno
#  Copia este archivo como .env y rellena los valores
# =============================================

# Base de datos (SQL Server) - Windows Authentication
# Intenta conectar con Windows Auth primero (Trusted_Connection)
DB_SERVER_WINDOWS=localhost
DB_INSTANCE_WINDOWS=SQLEXPRESS

# Base de datos (SQL Server) - SQL Authentication (Fallback)
# Si Windows Auth falla, usa estas credenciales
DB_SERVER=localhost
DB_PORT=49814
DB_INSTANCE=SQLEXPRESS
DB_USER=sa
DB_PASSWORD=123456

# Nombre de la base de datos
DB_NAME=barberia2

# JWT — Cambia esto por una clave larga y segura
JWT_SECRET=123456789

# Puerto del servidor
PORT=3000

# Debug mode (true/false) - Muestra logs detallados de conexión
DB_DEBUG=true
